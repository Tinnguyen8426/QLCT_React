@using System.Collections.Generic
@model QuanLyTiemCatToc.Models.Invoice
@{
    Layout = null;
    var paymentTranslations = new Dictionary<string, string>
    {
        ["Cash"] = "Tiền mặt",
        ["Card"] = "Thẻ",
        ["Transfer"] = "Chuyển khoản"
    };
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>In hóa đơn #@Model.InvoiceId</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.0/dist/css/bootstrap.min.css" />
    <style>
        body { padding: 24px; }
        .totals td { border-top: none !important; }
    </style>
    <script>
        window.onload = function(){ window.print(); }
    </script>
    </head>
<body>
    <div class="container">
        <div class="row">
            <div class="col-6">
                <h4>Tiệm Cắt Tóc</h4>
                <div>Ngày: @Model.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</div>
                <div>HĐ #: @Model.InvoiceId</div>
            </div>
            <div class="col-6 text-right">
                <div>Khách hàng: @Model.Customer?.FullName</div>
                <div>Nhân viên: @Model.Staff?.FullName</div>
                @{
                    var paymentKey = string.IsNullOrWhiteSpace(Model.PaymentMethod) ? string.Empty : Model.PaymentMethod;
                    var paymentLabel = string.IsNullOrEmpty(paymentKey) ? "-" : paymentTranslations.TryGetValue(paymentKey, out string methodLabel) ? methodLabel : paymentKey;
                }
                <div>Thanh toán: @paymentLabel</div>
            </div>
        </div>

        <hr />

        <table class="table table-sm">
            <thead>
                <tr>
                    <th>Loại</th>
                    <th>Tên</th>
                    <th class="text-right">SL</th>
                    <th class="text-right">Đơn giá</th>
                    <th class="text-right">Thành tiền</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in Model.InvoiceDetails)
                {
                    <tr>
                        <td>
                            @if (d.ServiceId.HasValue)
                            {
                                <small class="badge badge-primary">DV</small>
                            }
                            else if (d.ProductId.HasValue)
                            {
                                <small class="badge badge-success">SP</small>
                            }
                        </td>
                        <td>
                            @if (d.ServiceId.HasValue && d.Service != null)
                            {
                                @d.Service.ServiceName
                            }
                            else if (d.ProductId.HasValue && d.Product != null)
                            {
                                @d.Product.ProductName
                            }
                            else
                            {
                                <span class="text-muted">Đã xóa</span>
                            }
                        </td>
                        <td class="text-right">@d.Quantity</td>
                        <td class="text-right">@String.Format("{0:N0}", d.UnitPrice)</td>
                        <td class="text-right">@String.Format("{0:N0}", d.Subtotal)</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr class="totals">
                    <td colspan="4" class="text-right font-weight-bold">Tổng</td>
                    <td class="text-right">@String.Format("{0:N0}", Model.Total)</td>
                </tr>
                <tr class="totals">
                    <td colspan="4" class="text-right">Giảm giá</td>
                    <td class="text-right">@String.Format("{0:N0}", Model.Discount ?? 0)</td>
                </tr>
                <tr class="totals">
                    <td colspan="4" class="text-right font-weight-bold">Thành tiền</td>
                    <td class="text-right font-weight-bold">@String.Format("{0:N0}", Model.FinalAmount)</td>
                </tr>
            </tfoot>
        </table>

        <div class="text-center">Cảm ơn Quý khách!</div>
    </div>
</body>
</html>


