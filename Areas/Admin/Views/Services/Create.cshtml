@model QuanLyTiemCatToc.Models.Service
@{
    ViewData["Title"] = "Thêm dịch vụ";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="content-header">
    <div class="container-fluid">
        <h1 class="m-0">Thêm dịch vụ mới</h1>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="ServiceName">Tên dịch vụ <span class="text-danger">*</span></label>
                                <input asp-for="ServiceName" class="form-control" required />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Category">Danh mục</label>
                                <input asp-for="Category" class="form-control" placeholder="VD: Cắt tóc, Nhuộm, Uốn..." />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Price">Giá (VNĐ) <span class="text-danger">*</span></label>
                                <input asp-for="Price" type="number" class="form-control" required />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Duration">Thời lượng (phút)</label>
                                <input asp-for="Duration" type="number" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="IsActive">Trạng thái</label>
                                <select asp-for="IsActive" class="form-control">
                                    <option value="true">Hoạt động</option>
                                    <option value="false">Ẩn</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label asp-for="Description">Mô tả</label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="form-group">
                        <label>Hình ảnh</label>
                        <input type="file" name="ImageFile" class="form-control" accept="image/*" />
                    </div>
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-save"></i> Lưu
                    </button>
                    <a href="@Url.Action("Index")" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Hủy
                    </a>
                </div>
            </form>
        </div>
    </div>
</section>
