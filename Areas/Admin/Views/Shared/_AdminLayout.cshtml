<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản trị</title>
    <!-- Google Font: Source Sans Pro -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700&display=fallback">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="/AdminAssets/plugins/fontawesome-free/css/all.min.css">
    <!-- Ionicons -->
    <link rel="stylesheet" href="https://code.ionicframework.com/ionicons/2.0.1/css/ionicons.min.css">
    <!-- Theme style -->
    <link rel="stylesheet" href="/AdminAssets/dist/css/adminlte.min.css">
    <link rel="stylesheet" href="~/css/staff-dashboard.css" asp-append-version="true" />
</head>
<body class="hold-transition sidebar-mini layout-fixed dark-mode admin-shell">
    <div class="wrapper">
        <!-- Navbar -->
        <nav class="main-header navbar navbar-expand navbar-dark border-bottom-0">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
                </li>
                <li class="nav-item d-none d-sm-inline-block">
                    <a class="nav-link text-uppercase" asp-area="Admin" asp-controller="Home" asp-action="Index">Bảng điều khiển</a>
                </li>
            </ul>

            <ul class="navbar-nav ml-auto align-items-center">
                @if (User.Identity.IsAuthenticated)
                {
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-toggle="dropdown" aria-expanded="false">
                            @User.Identity.Name
                        </a>
                        <ul class="dropdown-menu dropdown-menu-right" aria-labelledby="navbarDropdown">
                            <li><a class="dropdown-item" asp-area="Admin" asp-controller="Home" asp-action="Index"><i class="fas fa-home mr-2 text-primary"></i>Trang chủ</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" id="logoutForm">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item text-danger"><i class="fas fa-sign-out-alt mr-2"></i>Đăng xuất</button>
                                </form>
                            </li>
                        </ul>
                    </li>
                }
            </ul>
        </nav>
        <!-- /.navbar -->
        <!-- Main Sidebar Container -->
        <aside class="main-sidebar sidebar-dark-primary elevation-4">
            <a href="/Admin" class="brand-link text-center">
                <span class="brand-text font-weight-light text-uppercase">Trung tâm quản trị</span>
            </a>

            <!-- Sidebar -->
            <div class="sidebar">
                <!-- Sidebar Menu -->
                <nav class="mt-2">
                    <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu" data-accordion="false">
                        <li class="nav-item">
                            <a class="nav-link @(ViewBag.ActiveMenu == "Home" ? "active" : "")" asp-area="Admin" asp-controller="Home" asp-action="Index">
                                <i class="nav-icon fas fa-tachometer-alt"></i>
                                <p>Tổng quan</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewBag.ActiveMenu == "Appointments" || ViewBag.ActiveMenu == "Calendar" ? "active" : "")" asp-area="Admin" asp-controller="Appointments" asp-action="Index">
                                <i class="nav-icon fas fa-calendar-alt"></i>
                                <p>Quản lý lịch hẹn</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewBag.ActiveMenu == "Calendar" ? "active" : "")" asp-area="Admin" asp-controller="Appointments" asp-action="Calendar">
                                <i class="nav-icon fas fa-calendar-day"></i>
                                <p>Lịch làm việc</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewBag.ActiveMenu == "Customers" ? "active" : "")" asp-area="Admin" asp-controller="Customers" asp-action="Index">
                                <i class="nav-icon fas fa-users"></i>
                                <p>Khách hàng</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewBag.ActiveMenu == "Invoices" ? "active" : "")" asp-area="Admin" asp-controller="Invoices" asp-action="Index">
                                <i class="nav-icon fas fa-file-invoice"></i>
                                <p>Hóa đơn</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewBag.ActiveMenu == "Reports" ? "active" : "")" asp-area="Admin" asp-controller="Reports" asp-action="Index">
                                <i class="nav-icon fas fa-chart-pie"></i>
                                <p>Báo cáo</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewBag.ActiveMenu == "Services" ? "active" : "")" asp-area="Admin" asp-controller="Services" asp-action="Index">
                                <i class="nav-icon fas fa-concierge-bell"></i>
                                <p>Dịch vụ</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewBag.ActiveMenu == "Products" ? "active" : "")" asp-area="Admin" asp-controller="Products" asp-action="Index">
                                <i class="nav-icon fas fa-box"></i>
                                <p>Mỹ phẩm</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewBag.ActiveMenu == "ProductOrders" ? "active" : "")" asp-area="Admin" asp-controller="ProductOrders" asp-action="Index">
                                <i class="nav-icon fas fa-truck"></i>
                                <p>Đơn mỹ phẩm</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewBag.ActiveMenu == "Users" ? "active" : "")" asp-area="Admin" asp-controller="Users" asp-action="Index">
                                <i class="nav-icon fas fa-user-cog"></i>
                                <p>Tài khoản</p>
                            </a>
                        </li>
                    </ul>
                </nav>
                <!-- /.sidebar-menu -->
            </div>
            <!-- /.sidebar -->
        </aside>

        <!-- Content Wrapper. Contains page content -->
        <div class="content-wrapper">
            <section class="content p-3 p-md-4">
                @RenderBody()
            </section>
        </div>
        <!-- /.content-wrapper -->

        <footer class="main-footer">
            <strong>Bản quyền &copy; 2025 <a href="#">QuanLyTiemCatToc</a>.</strong>
            Đã đăng ký mọi quyền.
        </footer>
    </div>
    <!-- ./wrapper -->
    <!-- jQuery -->
    <script src="/AdminAssets/plugins/jquery/jquery.min.js"></script>
    <!-- Bootstrap 4 -->
    <script src="/AdminAssets/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
    <!-- AdminLTE App -->
    <script src="/AdminAssets/dist/js/adminlte.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
