@model X.PagedList.IPagedList<QuanLyTiemCatToc.Models.User>
@using X.PagedList.Mvc.Core;
@{
    ViewData["Title"] = "Quản lý nhân viên";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="content-header">
    <div class="container-fluid">
        <h1 class="m-0">Quản lý nhân viên</h1>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Danh sách nhân viên</h3>
                <div class="card-tools">
                    <a href="@Url.Action("Create")" class="btn btn-success btn-sm">
                        <i class="fas fa-plus"></i> Thêm nhân viên
                    </a>
                </div>
            </div>
            <div class="card-body">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible">
                        <button type="button" class="close" data-dismiss="alert">&times;</button>
                        @TempData["SuccessMessage"]
                    </div>
                }

                <div class="table-responsive">
                    <table class="table table-bordered table-hover">
                        <thead>
                            <tr>
                                <th>Ảnh đại diện</th>
                                <th>Mã NV</th>
                                <th>Họ tên</th>
                                <th>Email</th>
                                <th>Số điện thoại</th>
                                <th>Vai trò</th>
                                <th>Ca làm</th>
                                <th>Hoa hồng (%)</th>
                                <th>Trạng thái</th>
                                <th>Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <img src="@(item.AvatarUrl ?? "/images/default-avatar.png")" alt="Ảnh đại diện" 
                                             class="img-circle elevation-2" style="width: 40px; height: 40px; object-fit: cover;" />
                                    </td>
                                    <td>@item.UserId</td>
                                    <td>@item.FullName</td>
                                    <td>@item.Email</td>
                                    <td>@(item.Phone ?? "-")</td>
                                    <td><span class="badge badge-info">@item.Role.RoleName</span></td>
                                    <td>@(item.Shift?.ShiftName ?? "-")</td>
                                    <td>@(item.CommissionPercent ?? 0)%</td>
                                    <td>
                                        @if (item.IsActive == true)
                                        {
                                            <span class="badge badge-success">Hoạt động</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-secondary">Ngừng</span>
                                        }
                                    </td>
                                    <td>
                                        <a href="@Url.Action("Details", new { id = item.UserId })" class="btn btn-info btn-sm" title="Chi tiết">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="@Url.Action("Edit", new { id = item.UserId })" class="btn btn-warning btn-sm" title="Sửa">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <button onclick="deleteUser(@item.UserId)" class="btn btn-danger btn-sm" title="Xóa">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                 <div class="card-footer clearfix">
                    @Html.PagedListPager(Model, page => Url.Action("Index", new { page }))
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        function deleteUser(id) {
            if (confirm('Bạn có chắc chắn muốn xóa nhân viên này?')) {
                fetch('/Admin/Users/Delete/' + id, { method: 'POST' })
                    .then(response => { if (response.ok) location.reload(); });
            }
        }
    </script>
}
