@model QuanLyTiemCatToc.Models.User
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Sửa nhân viên";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Sửa nhân viên</h1>
            </div>
            <div class="col-sm-6 text-right">
                <a class="btn btn-secondary" href="@Url.Action("Index")"><i class="fas fa-arrow-left"></i> Quay lại</a>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-body">
                <form asp-area="Admin" asp-controller="Users" asp-action="Edit" asp-route-id="@Model.UserId" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>
                    <input type="hidden" asp-for="UserId" />
                    <input type="hidden" asp-for="AvatarUrl" />
                    <input type="hidden" asp-for="CreatedAt" />

                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label>Họ tên</label>
                            <input class="form-control" asp-for="FullName" />
                            <span class="text-danger" asp-validation-for="FullName"></span>
                        </div>
                        <div class="form-group col-md-6">
                            <label>Email</label>
                            <input class="form-control" asp-for="Email" />
                            <span class="text-danger" asp-validation-for="Email"></span>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group col-md-4">
                            <label>Số điện thoại</label>
                            <input class="form-control" asp-for="Phone" />
                            <span class="text-danger" asp-validation-for="Phone"></span>
                        </div>
                        <div class="form-group col-md-4">
                            <label>Vai trò</label>
                            <select class="form-control" asp-for="RoleId" asp-items="ViewBag.RoleId"></select>
                            <span class="text-danger" asp-validation-for="RoleId"></span>
                        </div>
                        <div class="form-group col-md-4">
                            <label>Ca làm</label>
                            <select class="form-control" asp-for="ShiftId" asp-items="ViewBag.ShiftId"></select>
                            <span class="text-danger" asp-validation-for="ShiftId"></span>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group col-md-4">
                            <label>Hoa hồng (%)</label>
                            <input class="form-control" asp-for="CommissionPercent" />
                            <span class="text-danger" asp-validation-for="CommissionPercent"></span>
                        </div>
                        <div class="form-group col-md-4">
                            <label>Trạng thái</label>
                            <select class="form-control" asp-for="IsActive">
                                <option value="true">Đang làm</option>
                                <option value="false">Nghỉ</option>
                            </select>
                            <span class="text-danger" asp-validation-for="IsActive"></span>
                        </div>
                        <div class="form-group col-md-4">
                            <label>Ảnh đại diện</label>
                            <div class="custom-file">
                                <input type="file" class="custom-file-input" name="AvatarFile" />
                                <label class="custom-file-label">Chọn ảnh...</label>
                            </div>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label>Mật khẩu mới (để trống nếu giữ nguyên)</label>
                            <input type="password" class="form-control" name="NewPassword" />
                        </div>
                        <div class="form-group col-md-6">
                            @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                            {
                                <img src="@Model.AvatarUrl" alt="Ảnh đại diện" style="max-height:80px" class="mt-4" />
                            }
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Lưu thay đổi</button>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}


