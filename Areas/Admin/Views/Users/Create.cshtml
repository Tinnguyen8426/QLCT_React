@model QuanLyTiemCatToc.Models.User
@{
    ViewData["Title"] = "Thêm nhân viên";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="content-header">
    <div class="container-fluid">
        <h1 class="m-0">Thêm nhân viên mới</h1>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="card-body">
                    <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="FullName">Họ tên <span class="text-danger">*</span></label>
                                <input asp-for="FullName" class="form-control" required />
                                <span class="text-danger" asp-validation-for="FullName"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Email">Email <span class="text-danger">*</span></label>
                                <input asp-for="Email" type="email" class="form-control" required />
                                <span class="text-danger" asp-validation-for="Email"></span>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Phone">Số điện thoại</label>
                                <input asp-for="Phone" class="form-control" />
                                <span class="text-danger" asp-validation-for="Phone"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="PasswordHash">Mật khẩu <span class="text-danger">*</span></label>
                                <input asp-for="PasswordHash" type="password" class="form-control" required />
                                <span class="text-danger" asp-validation-for="PasswordHash"></span>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Vai trò <span class="text-danger">*</span></label>
                                <select asp-for="RoleId" class="form-control" asp-items="ViewBag.RoleId" required></select>
                                <span class="text-danger" asp-validation-for="RoleId"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Ca làm việc</label>
                                <select asp-for="ShiftId" class="form-control" asp-items="ViewBag.ShiftId">
                                    <option value="">-- Chọn ca --</option>
                                </select>
                                <span class="text-danger" asp-validation-for="ShiftId"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="CommissionPercent">Hoa hồng (%)</label>
                                <input asp-for="CommissionPercent" type="number" step="0.1" class="form-control" />
                                <span class="text-danger" asp-validation-for="CommissionPercent"></span>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Ảnh đại diện</label>
                                <input type="file" name="AvatarFile" class="form-control" accept="image/*" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="IsActive">Trạng thái</label>
                                <select asp-for="IsActive" class="form-control">
                                    <option value="true">Hoạt động</option>
                                    <option value="false">Ngừng</option>
                                </select>
                                <span class="text-danger" asp-validation-for="IsActive"></span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-save"></i> Lưu
                    </button>
                    <a href="@Url.Action("Index")" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Hủy
                    </a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
