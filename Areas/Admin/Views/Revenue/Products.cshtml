@{
    ViewData["Title"] = "Thống kê doanh thu theo sản phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<!-- Content Header (Page header) -->
<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Thống kê doanh thu theo sản phẩm</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="/Admin">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a href="/Admin/Revenue">Thống kê doanh thu</a></li>
                    <li class="breadcrumb-item active">Theo sản phẩm</li>
                </ol>
            </div>
        </div>
    </div>
</div>
<!-- /.content-header -->

<!-- Main content -->
<section class="content">
    <div class="container-fluid">
        <!-- Info boxes -->
        <div class="row">
            <div class="col-12">
                <div class="info-box">
                    <span class="info-box-icon bg-info elevation-1"><i class="fas fa-money-bill-wave"></i></span>
                    <div class="info-box-content">
                        <span class="info-box-text">Tổng doanh thu từ sản phẩm</span>
                        <span class="info-box-number">
                            @ViewBag.TotalRevenue.ToString("N0") <small>VNĐ</small>
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main row -->
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Danh sách doanh thu theo sản phẩm</h3>
                        <div class="card-tools">
                            <div class="input-group input-group-sm" style="width: 250px;">
                                <input type="text" name="table_search" id="product-search" class="form-control float-right" placeholder="Tìm kiếm sản phẩm...">
                                <div class="input-group-append">
                                    <button type="button" class="btn btn-default">
                                        <i class="fas fa-search"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- /.card-header -->
                    <div class="card-body table-responsive p-0">
                        <table class="table table-hover text-nowrap" id="product-revenue-table">
                            <thead>
                                <tr>
                                    <th>Mã</th>
                                    <th>Tên sản phẩm</th>
                                    <th>Danh mục</th>
                                    <th>Số lượng đã bán</th>
                                    <th>Doanh thu</th>
                                    <th>Tỷ lệ</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    decimal totalRevenue = ViewBag.TotalRevenue > 0 ? ViewBag.TotalRevenue : 1;
                                }
                                @foreach (var item in ViewBag.ProductRevenueData)
                                {
                                    <tr>
                                        <td>@item.ProductId</td>
                                        <td><a href="/Admin/AdminProduct/Details/@item.ProductId">@item.ProductName</a></td>
                                        <td>@item.CategoryName</td>
                                        <td>@item.QuantitySold</td>
                                        <td>@item.Revenue.ToString("N0") VNĐ</td>
                                        <td>
                                            <div class="progress progress-xs">
                                                <div class="progress-bar bg-primary" style="width: @((item.Revenue / totalRevenue * 100).ToString("0"))%"></div>
                                            </div>
                                            <span class="badge bg-primary">@((item.Revenue / totalRevenue * 100).ToString("0.0"))%</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <!-- /.card-body -->
                </div>
                <!-- /.card -->
            </div>
        </div>
    </div>
</section>
<!-- /.content -->

@section Scripts {
    <script>
        // Tìm kiếm sản phẩm trong bảng
        $(document).ready(function () {
            $("#product-search").on("keyup", function () {
                var value = $(this).val().toLowerCase();
                $("#product-revenue-table tbody tr").filter(function () {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
                });
            });
        });
    </script>
}
