@using System
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Khu vực nhân viên</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap">
    <link rel="stylesheet" href="/AdminAssets/plugins/fontawesome-free/css/all.min.css">
    <link rel="stylesheet" href="/AdminAssets/dist/css/adminlte.min.css">
    <link rel="stylesheet" href="~/css/staff-dashboard.css" asp-append-version="true" />
</head>
<body class="hold-transition sidebar-mini layout-fixed dark-mode">
    <div class="wrapper">
        <nav class="main-header navbar navbar-expand navbar-dark border-bottom-0">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
                </li>
                <li class="nav-item d-none d-sm-inline-block">
                    <a class="nav-link text-uppercase" asp-area="Staff" asp-controller="Home" asp-action="Index">Bảng điều khiển</a>
                </li>
            </ul>
            <ul class="navbar-nav ml-auto align-items-center">
                @if (User.Identity.IsAuthenticated)
                {
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-toggle="dropdown" aria-expanded="false">
                            <i class="fas fa-user-circle mr-1"></i>@User.Identity.Name
                        </a>
                        <div class="dropdown-menu dropdown-menu-right">
                            <a class="dropdown-item" asp-area="Staff" asp-controller="Home" asp-action="Index"><i class="fas fa-home mr-2 text-primary"></i>Trang chủ</a>
                            <div class="dropdown-divider"></div>
                            <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" id="logoutForm">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item text-danger">
                                    <i class="fas fa-sign-out-alt mr-2"></i>Đăng xuất
                                </button>
                            </form>
                        </div>
                    </li>
                }
            </ul>
        </nav>

        <aside class="main-sidebar sidebar-dark-primary elevation-4">
            <a href="/Staff" class="brand-link text-center">
                <span class="brand-text font-weight-light">k.gian nhân viên</span>
            </a>
            <div class="sidebar">
                <nav class="mt-3">
                    <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu">
                        <li class="nav-item">
                            <a class="nav-link @(ViewBag.ActiveMenu == "Home" ? "active" : "")" asp-area="Staff" asp-controller="Home" asp-action="Index">
                                <i class="nav-icon fas fa-tachometer-alt"></i>
                                <p>Tổng quan</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewBag.ActiveMenu == "Appointments" ? "active" : "")" asp-area="Staff" asp-controller="Appointments" asp-action="Index">
                                <i class="nav-icon fas fa-calendar-check"></i>
                                <p>Lịch hẹn của tôi</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewBag.ActiveMenu == "ProductOrders" ? "active" : "")" asp-area="Staff" asp-controller="ProductOrders" asp-action="Index">
                                <i class="nav-icon fas fa-box-open"></i>
                                <p>Đơn mỹ phẩm</p>
                            </a>
                        </li>
                         <li class="nav-item">
                            <a class="nav-link" href="/Booking">
                                <i class="nav-icon fas fa-plus-circle"></i>
                                <p>Tạo Lịch hẹn mới</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Profile" asp-action="Index">
                                <i class="nav-icon fas fa-user-cog"></i>
                                <p>Thông tin cá nhân</p>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        </aside>

        <div class="content-wrapper">
            <section class="content p-3 p-md-4">
                @RenderBody()
            </section>
        </div>

        <footer class="main-footer bg-transparent border-top-0 text-muted small">
            <div class="text-center">
                Bản quyền &copy; 2025 <strong>QuanLyTiemCatToc</strong>. Đã đăng ký bản quyền.
            </div>
        </footer>
    </div>

    <script src="/AdminAssets/plugins/jquery/jquery.min.js"></script>
    <script src="/AdminAssets/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/AdminAssets/dist/js/adminlte.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
