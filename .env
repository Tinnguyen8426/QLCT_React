# MẬT KHẨU QUẢN TRỊ VIÊN SQL SERVER (SA_PASSWORD)
# Yêu cầu: Ít nhất 8 ký tự, gồm số, chữ và ký tự đặc biệt
SA_PASSWORD=SuperStrong!Password2026

# KHOÁ BẢO MẬT JWT DÙNG ĐỂ TẠO TOKEN ĐĂNG NHẬP
# Yêu cầu: Chuỗi bất kỳ, độ dài tối thiểu 32 bytes (như bên dưới)
JWT_KEY=CHANGE_ME_TO_A_SUPER_SECRET_KEY_32BYTES_LONG

# ĐỊA CHỈ API CÔNG KHAI (CHỈ DÙNG KHI DEPLOY LÊN AZURE)
# Nếu chạy ở Local bằng Docker Desktop, giữ nguyên localhost:5289
VITE_API_URL=http://localhost:5289
