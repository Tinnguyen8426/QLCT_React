@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

<section class="container" style="padding:24px 0; max-width:400px; margin:0 auto;">
    <h1 style="margin:0 0 16px; text-align:center;">Quên mật khẩu</h1>
    @if (TempData["InfoMessage"] != null)
    {
        <div style="border:1px solid #007bff; color:#004085; background:#cce5ff; padding:12px; border-radius:8px; margin-bottom:16px;">
            @TempData["InfoMessage"]
        </div>
    }
    @if (!ViewData.ModelState.IsValid)
    {
        <div style="border:1px solid #f00; color:#b00020; padding:12px; border-radius:8px; margin-bottom:16px;">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div>@error.ErrorMessage</div>
            }
        </div>
    }
    <form method="post" style="border:1px solid #eee; border-radius:12px; padding:20px;">
        <div style="margin-bottom:12px;">
            <label>Email</label>
            <input class="form-control" type="email" name="email" placeholder="Nhập email của bạn" required autofocus />
        </div>
        <button class="btn primary" type="submit" style="width:100%;">Gửi yêu cầu</button>
    </form>
    <div style="text-align:center; margin-top:16px;">
        <a href="@Url.Action("Login")">Quay lại đăng nhập</a>
    </div>
</section>

