@{
    ViewData["Title"] = "Từ chối truy cập";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

<section class="py-5">
    <div class="container" style="max-width:640px;">
        <div class="text-center border border-danger-subtle rounded-4 p-4 p-md-5 bg-black bg-opacity-50" style="backdrop-filter:blur(12px);">
            <div class="display-5 text-danger mb-3">
                <i class="fa-solid fa-triangle-exclamation"></i>
            </div>
            <h1 class="h3 fw-semibold mb-3">Bạn không có quyền truy cập</h1>
            <p class="text-white-50 mb-4">
                Tài khoản hiện tại không được phép vào khu vực này. Nếu bạn nghĩ đây là nhầm lẫn, vui lòng liên hệ quản trị viên để được hỗ trợ phân quyền.
            </p>
            <div class="d-flex flex-column flex-md-row gap-3 justify-content-center">
                <a class="btn btn-light px-4" href="/">Về trang chủ</a>
                <a class="btn btn-outline-light px-4" href="/Account/Login">Đăng nhập bằng tài khoản khác</a>
            </div>
        </div>
    </div>
</section>
