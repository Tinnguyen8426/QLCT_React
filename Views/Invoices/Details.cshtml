@model QuanLyTiemCatToc.Models.Invoice
@{
    ViewData["Title"] = "Chi tiết hóa đơn";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
    Func<QuanLyTiemCatToc.Models.InvoiceDetail, string> itemName = d =>
        d.ServiceId.HasValue ? d.Service?.ServiceName ?? "Dịch vụ" :
        d.ProductId.HasValue ? d.Product?.ProductName ?? "Sản phẩm" : "Mục";
}

<section class="container" style="padding:24px 0;">
    <h1 style="margin:0 0 16px;">Hóa đơn #@Model.InvoiceId</h1>
    <div class="invoice-dark-box" style="border-radius:14px; padding:20px; margin-bottom:16px;">
        <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap:16px; margin-bottom:20px;">
            <div>
                <div style="font-size:12px; color:rgba(245,246,251,0.65); margin-bottom:4px;">Ngày tạo</div>
                <div>@Model.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</div>
            </div>
            <div>
                <div style="font-size:12px; color:rgba(245,246,251,0.65); margin-bottom:4px;">Khách hàng</div>
                <div>@Model.Customer?.FullName</div>
            </div>
            <div>
                <div style="font-size:12px; color:rgba(245,246,251,0.65); margin-bottom:4px;">Nhân viên</div>
                <div>@(Model.Staff?.FullName ?? "-")</div>
            </div>
            <div>
                <div style="font-size:12px; color:rgba(245,246,251,0.65); margin-bottom:4px;">Thanh toán</div>
                <div>@Model.PaymentMethod</div>
            </div>
        </div>

        <table style="width:100%; border-collapse:collapse; margin-top:8px; color:#f5f6fb;">
            <thead>
                <tr style="border-bottom:1px solid rgba(255,255,255,0.16); color:#f5f6fb;">
                    <th style="text-align:left; padding:10px 0;">Mục</th>
                    <th style="text-align:right; padding:10px 0;">SL</th>
                    <th style="text-align:right; padding:10px 0;">Đơn giá</th>
                    <th style="text-align:right; padding:10px 0;">Thành tiền</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in Model.InvoiceDetails)
                {
                    <tr style="border-bottom:1px solid rgba(255,255,255,0.08);">
                        <td style="padding:10px 0;">@itemName(d)</td>
                        <td style="text-align:right; padding:10px 0;">@d.Quantity</td>
                        <td style="text-align:right; padding:10px 0;">@String.Format("{0:N0} đ", d.UnitPrice)</td>
                        <td style="text-align:right; padding:10px 0;">@String.Format("{0:N0} đ", d.Subtotal)</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr style="border-top:1px solid rgba(255,255,255,0.16);">
                    <td colspan="3" style="text-align:right; padding:10px 0; font-weight:600;">Tổng</td>
                    <td style="text-align:right; padding:10px 0; font-weight:600;">@String.Format("{0:N0} đ", Model.Total)</td>
                </tr>
                <tr>
                    <td colspan="3" style="text-align:right; padding:10px 0;">Giảm giá</td>
                    <td style="text-align:right; padding:10px 0;">@String.Format("{0:N0} đ", Model.Discount ?? 0)</td>
                </tr>
                <tr style="border-top:1px solid rgba(255,255,255,0.16);">
                    <td colspan="3" style="text-align:right; padding:12px 0; font-weight:700; font-size:18px;">Thành tiền</td>
                    <td style="text-align:right; padding:12px 0; font-weight:700; font-size:18px;">@String.Format("{0:N0} đ", Model.FinalAmount)</td>
                </tr>
            </tfoot>
        </table>
    </div>
    <div style="display:flex; gap:12px;">
        <button class="btn primary" onclick="window.print()">In hóa đơn</button>
        <a class="btn light" href="/Invoices/History">Quay lại</a>
    </div>
</section>

<style>
    @@media print {
        .header, .footer, .btn { display: none; }
    }
</style>

