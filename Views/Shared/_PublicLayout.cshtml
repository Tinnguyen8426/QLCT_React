@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@inject QuanLyTiemCatToc.Models.QuanLyTiemCatTocContext _context
@using System.Security.Claims
@{
    Layout = null;
    var title = ViewData["Title"] as string ?? "Barber";
    var cartItems = HttpContextAccessor.HttpContext?.Session?.GetCart() ?? new List<CartItemViewModel>();
    var cartCount = cartItems.Sum(i => i.Quantity);
    var googlePlacesKey = Configuration["Google:PlacesApiKey"];
    string avatarUrl = null;
    if (User.Identity.IsAuthenticated)
    {
        var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
        if(userId != null)
        {
            var user = _context.Users.Find(int.Parse(userId));
            if (user != null && !string.IsNullOrWhiteSpace(user.AvatarUrl))
            {
                avatarUrl = user.AvatarUrl;
            }
        }
    }
}
<!DOCTYPE html>
<html lang="vi" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title</title>
    @if (!string.IsNullOrWhiteSpace(googlePlacesKey))
    {
        <meta name="google-places-key" content="@googlePlacesKey" />
    }
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/public.css" />
    <link rel="stylesheet" href="/css/profile-dark.css" />
    @if (new[] { "Feedback", "Appointments", "Invoices", "Booking" }.Contains(ViewContext.RouteData.Values["controller"] as string))
    {
        <link rel="stylesheet" href="/css/feedback-dark.css" />
    }
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: #151520;
            color: #e6e6f0;
        }
        .navbar-brand {
            font-weight: 700;
            letter-spacing: 0.05em;
        }
        .nav-link {
            text-transform: uppercase;
            font-size: 0.85rem;
            letter-spacing: 0.08em;
        }
        .nav-link.active,
        .nav-link:hover {
            color: #fff !important;
        }
        .btn-ghost {
            border: 1px solid rgba(255, 255, 255, 0.4);
            border-radius: 999px;
            padding-inline: 1.5rem;
        }
        main {
            backdrop-filter: blur(12px);
        }
        .navbar .avatar {
            width: 24px;
            height: 24px;
            object-fit: cover;
            border-radius: 50%;
            margin-right: 8px;
        }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">
    <header class="border-bottom border-secondary-subtle">
        <nav class="navbar navbar-expand-lg navbar-dark bg-black bg-opacity-75 py-3">
            <div class="container-fluid px-3 px-md-4 px-lg-5">
                <a class="navbar-brand" href="/">Barber.</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse justify-content-end" id="mainNav">
                    <ul class="navbar-nav gap-2 align-items-lg-center">
                        <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"] as string == "Home" ? "active" : "")" href="/">Trang chủ</a></li>
                        <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"] as string == "Services" ? "active" : "")" href="/Services">Dịch vụ</a></li>
                        <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"] as string == "Booking" ? "active" : "")" href="/Booking">Đặt lịch</a></li>
                        <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"] as string == "Appointments" ? "active" : "")" href="/Appointments/MyAppointments">Lịch hẹn</a></li>
                        <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"] as string == "Invoices" ? "active" : "")" href="/Invoices/History">Lịch sử</a></li>
                        <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"] as string == "Feedback" ? "active" : "")" href="/Feedback">Đánh giá</a></li>
                        <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"] as string == "Store" ? "active" : "")" href="/Store">Mỹ phẩm</a></li>
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center gap-2" href="/Cart" data-cart-count="@cartCount">
                                <i class="fa-solid fa-bag-shopping"></i>
                                <span>Giỏ hàng</span>
                                <span class="badge bg-danger rounded-pill" id="cart-count-badge" data-cart-count-target>@cartCount</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            @if (User.Identity.IsAuthenticated)
                            {
                                <div class="dropdown">
                                    <a class="btn btn-outline-light btn-sm btn-ghost dropdown-toggle d-flex align-items-center" href="#" role="button" id="dropdownMenuLink" data-bs-toggle="dropdown" aria-expanded="false">
                                        @if (avatarUrl != null)
                                        {
                                            <img src="@avatarUrl" alt="Avatar" class="avatar">
                                        }
                                        else
                                        {
                                            <i class="fa-regular fa-user me-2"></i>
                                        }
                                        @User.Identity.Name
                                    </a>

                                    <ul class="dropdown-menu" aria-labelledby="dropdownMenuLink">
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <li><a class="dropdown-item" href="/Admin">Trang quản trị</a></li>
                                        }
                                        @if (User.IsInRole("Staff"))
                                        {
                                            <li><a class="dropdown-item" href="/Staff">Bảng điều khiển nhân viên</a></li>
                                        }
                                        @if (User.IsInRole("Customer"))
                                        {
                                            <li><a class="dropdown-item" asp-controller="CustomerPortal" asp-action="Dashboard">Trung tâm khách hàng</a></li>
                                            <li><a class="dropdown-item" asp-controller="CustomerPortal" asp-action="Products">Kho mỹ phẩm</a></li>
                                        }
                                        <li><hr class="dropdown-divider" /></li>
                                        <li><a class="dropdown-item" href="/Profile">Thông tin cá nhân</a></li>
                                        <li>
                                            <form asp-controller="Account" asp-action="Logout" method="post" id="logoutForm">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="dropdown-item">Đăng xuất</button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            }
                            else
                            {
                                <a class="btn btn-outline-light btn-sm btn-ghost" href="/Account/Login">
                                    <i class="fa-regular fa-user me-2"></i>Đăng nhập
                                </a>
                            }
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="flex-grow-1 py-5">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer class="bg-black bg-opacity-75 border-top border-secondary-subtle py-4">
        <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center gap-3 text-muted small">
            <div>© @(DateTime.Now.Year) Barber Salon</div>
            <div class="d-flex align-items-center gap-3 flex-wrap">
                <span><i class="fa-regular fa-clock me-1"></i>09:00 - 20:00 (T2 - CN)</span>
                <span><i class="fa-solid fa-phone me-1"></i>0900 000 000</span>
                <a class="btn btn-outline-light btn-sm" href="/Contact"><i class="fa-regular fa-paper-plane me-1"></i>Liên hệ</a>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
