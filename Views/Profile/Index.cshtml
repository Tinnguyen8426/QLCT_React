@model QuanLyTiemCatToc.Models.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "Hồ sơ";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
    var avatar = string.IsNullOrWhiteSpace(Model.AvatarUrl)
        ? "https://images.unsplash.com/photo-1524504388940-b1c1722653e1?auto=format&fit=crop&w=800&q=80"
        : Model.AvatarUrl;
}

<section class="py-4 profile-page">
    <div class="container">
        <div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
            <div>
                <p class="text-uppercase text-muted small mb-1">Tài khoản của tôi</p>
                <h1 class="h3 mb-0">Hồ sơ & bảo mật</h1>
                <div class="text-muted small mt-1">Cập nhật thông tin liên hệ, ảnh đại diện và mật khẩu.</div>
            </div>
            <div class="text-end">
                <span class="badge bg-dark text-light">Vai trò: @(string.IsNullOrWhiteSpace(Model.RoleName) ? "Người dùng" : Model.RoleName)</span>
                @if (Model.CreatedAt.HasValue)
                {
                    <div class="text-muted small mt-1">Tham gia: @Model.CreatedAt.Value.ToString("dd/MM/yyyy")</div>
                }
            </div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success shadow-sm">@TempData["SuccessMessage"]</div>
        }
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger shadow-sm">Vui lòng kiểm tra lại các trường nhập.</div>
        }

        <form method="post" enctype="multipart/form-data" novalidate>
        <div class="row g-4 align-items-start">
            <div class="col-lg-4">
                <div class="card h-100 p-4 p-md-5">
                    <div class="card-body text-center">
                        <div class="position-relative d-inline-block mb-3">
                            <img src="@avatar" alt="Avatar" class="rounded-circle shadow-sm" style="width:120px;height:120px;object-fit:cover;" id="avatar-preview">
                        </div>
                        <div class="mb-2">
                            <label class="form-label fw-semibold">Tải ảnh đại diện</label>
                            <input class="form-control" type="file" name="avatarFile" accept="image/*" id="avatar-file">
                        </div>
                        <p class="text-muted small mb-1">Hoặc dùng URL ảnh</p>
                        <input type="text" name="AvatarUrl" value="@Model.AvatarUrl" class="form-control text-center" placeholder="https://">
                        @Html.ValidationMessage("AvatarUrl", "", new { @class = "text-danger small" })
                    </div>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="card p-4 p-md-5">
                    <div class="card-body">
                        
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="UserId" value="@Model.UserId" />
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Họ tên</label>
                                    <input class="form-control" type="text" name="FullName" value="@Model.FullName" required>
                                    @Html.ValidationMessageFor(m => m.FullName, "", new { @class = "text-danger small" })
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Email</label>
                                    <input class="form-control" type="email" name="Email" value="@Model.Email" required>
                                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small" })
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Số điện thoại</label>
                                    <input class="form-control" type="tel" name="Phone" value="@Model.Phone">
                                    @Html.ValidationMessageFor(m => m.Phone, "", new { @class = "text-danger small" })
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Mật khẩu mới</label>
                                    <input class="form-control" type="password" name="NewPassword" autocomplete="new-password" placeholder="Để trống nếu giữ nguyên">
                                    @Html.ValidationMessageFor(m => m.NewPassword, "", new { @class = "text-danger small" })
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Xác nhận mật khẩu</label>
                                    <input class="form-control" type="password" name="ConfirmPassword" autocomplete="new-password" placeholder="Nhập lại mật khẩu mới">
                                    @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger small" })
                                </div>
                            </div>
                            <div class="d-flex justify-content-end gap-2 mt-4">
                                <a class="btn btn-outline-secondary" href="/">Về trang chủ</a>
                                <button class="btn btn-dark" type="submit"><i class="fa-regular fa-floppy-disk me-2"></i>Lưu thay đổi</button>
                            </div>
                        
                    </div>
                </div>
            </div>
        </div>
    </form>
    </div>
</section>

<script>
    const fileInput = document.getElementById('avatar-file');
    if (fileInput) {
        fileInput.addEventListener('change', (e) => {
            const [file] = e.target.files;
            if (file) {
                const preview = document.getElementById('avatar-preview');
                if (preview) {
                    preview.src = URL.createObjectURL(file);
                }
            }
        });
    }
</script>

