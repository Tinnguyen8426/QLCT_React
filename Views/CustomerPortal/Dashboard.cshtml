@using System.Collections.Generic
@using System.Linq
@model QuanLyTiemCatToc.Models.ViewModels.CustomerDashboardViewModel
@{
    ViewData["Title"] = "Trung tâm khách hàng";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
    var statusTranslations = new Dictionary<string, string>
    {
        ["Pending"] = "Chờ xác nhận",
        ["Confirmed"] = "Đã xác nhận",
        ["Completed"] = "Hoàn thành",
        ["Cancelled"] = "Đã hủy",
        ["No-show"] = "Vắng mặt"
    };
}

<section class="pb-5">
    <div class="mb-4">
        <h1 class="h3 fw-semibold">Xin chào, @Model.User.FullName!</h1>
        <p class="text-white-50 mb-0">Quản lý lịch hẹn và chi tiêu chăm sóc tóc của bạn tại đây.</p>
    </div>

    @if (TempData["WarningMessage"] != null)
    {
        <div class="alert alert-warning border-warning-subtle bg-transparent text-white-50">@TempData["WarningMessage"]</div>
    }

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="p-4 rounded-4 border border-secondary-subtle bg-black bg-opacity-50">
                <div class="text-white-50 mb-2">Tổng lịch hẹn</div>
                <div class="display-6 fw-semibold">@Model.TotalAppointments</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-4 rounded-4 border border-secondary-subtle bg-black bg-opacity-50">
                <div class="text-white-50 mb-2">Lịch sắp tới</div>
                <div class="display-6 fw-semibold">@Model.UpcomingAppointments</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-4 rounded-4 border border-secondary-subtle bg-black bg-opacity-50">
                <div class="text-white-50 mb-2">Tổng chi tiêu</div>
                <div class="display-6 fw-semibold">@Model.TotalSpending.ToString("N0") đ</div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="p-4 rounded-4 border border-secondary-subtle bg-black bg-opacity-50 h-100">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="h5 mb-0">Lịch hẹn sắp tới</h2>
                    <a class="btn btn-sm btn-outline-light" asp-controller="CustomerPortal" asp-action="Appointments">Xem tất cả</a>
                </div>
                @if (Model.Customer == null || !Model.NextAppointments.Any())
                {
                    <p class="text-white-50 mb-0">Chưa có lịch hẹn nào.</p>
                }
                else
                {
                    foreach (var apt in Model.NextAppointments)
                    {
                        var statusKey = string.IsNullOrWhiteSpace(apt.Status) ? "Pending" : apt.Status;
                        var statusLabel = statusTranslations.TryGetValue(statusKey, out var label) ? label : statusKey;
                        <div class="border-bottom border-secondary-subtle py-3">
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div>
                                    <div class="fw-semibold">@string.Join(", ", apt.AppointmentDetails.Where(d => d.Service != null).Select(d => d.Service!.ServiceName))</div>
                                    <div class="text-white-50 small">@apt.AppointmentDate.ToString("dd/MM/yyyy") - @apt.AppointmentTime.ToString("HH:mm")</div>
                                    <div class="text-white-50 small">Phụ trách: @(apt.Staff?.FullName ?? "Đang phân công")</div>
                                </div>
                                <span class="badge text-bg-light text-dark">@statusLabel</span>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
        <div class="col-lg-6">
            <div class="p-4 rounded-4 border border-secondary-subtle bg-black bg-opacity-50 h-100">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="h5 mb-0">Hóa đơn gần đây</h2>
                    <a class="btn btn-sm btn-outline-light" asp-controller="CustomerPortal" asp-action="Invoices">Xem tất cả</a>
                </div>
                @if (Model.Customer == null || !Model.RecentInvoices.Any())
                {
                    <p class="text-white-50 mb-0">Chưa có hóa đơn nào.</p>
                }
                else
                {
                    foreach (var invoice in Model.RecentInvoices)
                    {
                        <div class="border-bottom border-secondary-subtle py-3">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <div class="fw-semibold">HĐ #@invoice.InvoiceId</div>
                                    <div class="text-white-50 small">@invoice.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</div>
                                    <div class="text-white-50 small">Thực hiện: @(invoice.Staff?.FullName ?? "Không rõ")</div>
                                </div>
                                <div class="text-end">
                                    <div class="fw-semibold">@((invoice.FinalAmount ?? 0).ToString("N0")) đ</div>
                                    <a class="btn btn-link btn-sm text-white-50" asp-controller="Invoices" asp-action="Details" asp-route-id="@invoice.InvoiceId">Chi tiết</a>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</section>
