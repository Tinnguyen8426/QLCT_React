@model CustomerProductsViewModel
@{
    ViewData["Title"] = "Mỹ phẩm đã mua";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="fw-semibold mb-1">Tủ mỹ phẩm của @Model.User.FullName</h1>
        <small class="text-muted">Theo dõi các sản phẩm đã từng sử dụng tại salon và đặt lại chỉ bằng một chạm.</small>
    </div>
    <a href="/Store" class="btn btn-outline-light">Mua thêm</a>
</div>

@if (TempData["WarningMessage"] != null)
{
    <div class="alert alert-warning">@TempData["WarningMessage"]</div>
}

<div class="row g-4 mb-5">
    <div class="col-lg-6">
        <div class="card bg-dark border-secondary-subtle h-100">
            <div class="card-body">
                <h5 class="card-title">Đã dùng gần đây</h5>
                @if (!Model.PurchasedProducts.Any())
                {
                    <p class="text-muted small mb-0">Chưa có sản phẩm nào trong lịch sử hóa đơn.</p>
                }
                else
                {
                    foreach (var product in Model.PurchasedProducts)
                    {
                        <div class="border-bottom border-secondary-subtle py-3">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <div class="fw-semibold">@product.ProductName</div>
                                    <small class="text-muted">Mua lần cuối: @(product.LastPurchasedAt?.ToString("dd/MM/yyyy") ?? "Đang cập nhật")</small>
                                </div>
                                <div class="text-end">
                                    <div class="fw-semibold">@product.Price.ToString("N0") đ</div>
                                    <small class="text-muted">Đã mua @product.PurchasedQuantity lần</small>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        @await Html.PartialAsync("_CartSummary", Model.Cart)
    </div>
</div>

<div class="mb-3 d-flex justify-content-between align-items-center">
    <h2 class="fw-semibold mb-0">Đặt lại nhanh</h2>
    <small class="text-muted">Các sản phẩm bạn từng dùng sẽ được ưu tiên đề xuất.</small>
</div>

@if (!Model.PurchasedProducts.Any())
{
    <div class="text-muted mb-5">Bạn chưa sử dụng mỹ phẩm nào tại salon. Hãy khám phá cửa hàng để được tư vấn.</div>
}
else
{
    <div class="row g-4 mb-5">
        @foreach (var product in Model.PurchasedProducts)
        {
            <div class="col-md-4">
                <div class="card h-100 border-secondary-subtle bg-black bg-opacity-50">
                    <img src="@product.ImageUrl" alt="@product.ProductName" class="card-img-top" style="height: 200px; object-fit: cover;">
                    <div class="card-body d-flex flex-column">
                        <h5>@product.ProductName</h5>
                        <small class="text-muted mb-2">Mua lần cuối: @(product.LastPurchasedAt?.ToString("dd/MM/yyyy") ?? "N/A")</small>
                        <p class="text-muted small flex-grow-1">@product.Description</p>
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <strong>@product.Price.ToString("N0") đ</strong>
                            <form asp-controller="Cart" asp-action="Add" method="post" class="add-to-cart-form" data-product="@product.ProductName">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@product.ProductId" />
                                <input type="hidden" name="quantity" value="1" />
                                <button class="btn add-to-cart-btn btn-sm text-dark fw-semibold border-0" type="submit">
                                    <i class="fa-solid fa-cart-plus me-1"></i>Đặt lại
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<div class="mb-3 d-flex justify-content-between align-items-center">
    <h2 class="fw-semibold mb-0">Gợi ý cho bạn</h2>
    <small class="text-muted">Dựa trên xu hướng bán chạy tại salon</small>
</div>

@if (!Model.RecommendedProducts.Any())
{
    <div class="text-muted">Chúng tôi đang thu thập thêm dữ liệu để gợi ý chính xác hơn.</div>
}
else
{
    <div class="row g-4">
        @foreach (var product in Model.RecommendedProducts)
        {
            <div class="col-md-4">
                <div class="card h-100 border-secondary-subtle bg-black bg-opacity-50">
                    <img src="@product.ImageUrl" alt="@product.ProductName" class="card-img-top" style="height: 200px; object-fit: cover;">
                    <div class="card-body d-flex flex-column">
                        <h5>@product.ProductName</h5>
                        <p class="text-muted small flex-grow-1">@product.Description</p>
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <strong>@product.Price.ToString("N0") đ</strong>
                            <form asp-controller="Cart" asp-action="Add" method="post" class="add-to-cart-form" data-product="@product.ProductName">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@product.ProductId" />
                                <input type="hidden" name="quantity" value="1" />
                                <button class="btn add-to-cart-btn btn-sm text-dark fw-semibold border-0" type="submit">
                                    <i class="fa-solid fa-cart-plus"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <script src="/js/storefront.js" asp-append-version="true"></script>
}
